<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.UsersAdminController"
            styleClass="admin-root"
            stylesheets="@../css/styles-admin.css">

    <left>
        <VBox styleClass="admin-sidebar" spacing="4" prefWidth="230">
            <padding><Insets top="28" right="12" bottom="28" left="12"/></padding>
            <Label text="🛠 Admin Panel" styleClass="sidebar-logo"/>
            <Separator style="-fx-opacity:0.25;"/>
            <Button text="📊 Dashboard"    styleClass="sidebar-btn"        maxWidth="Infinity" onAction="#retourDashboard"/>
            <Button text="📦 Produits"     styleClass="sidebar-btn"        maxWidth="Infinity" onAction="#ouvrirProduits"/>
            <Button text="📋 Commandes"    styleClass="sidebar-btn"        maxWidth="Infinity" onAction="#ouvrirCommandes"/>
            <Button text="👥 Utilisateurs" styleClass="sidebar-btn-active" maxWidth="Infinity"/>
            <Button text="🏷 Catégories"   styleClass="sidebar-btn"        maxWidth="Infinity" onAction="#ouvrirCategories"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="🚪 Déconnexion"  styleClass="sidebar-btn-logout" maxWidth="Infinity" onAction="#seDeconnecter"/>
        </VBox>
    </left>

    <center>
        <HBox spacing="18">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <VBox spacing="14" HBox.hgrow="ALWAYS">
                <Label text="👥 Gestion des Utilisateurs" styleClass="admin-page-title"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField"
                               promptText="🔍 Rechercher..."
                               styleClass="admin-search" prefWidth="280"/>
                    <Label fx:id="countLabel" styleClass="admin-count"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="➕ Nouveau" styleClass="admin-btn-primary"
                            onAction="#nouveau"/>
                </HBox>
                <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="admin-table">
                    <columns>
                        <TableColumn fx:id="colId"       text="ID"       prefWidth="60"/>
                        <TableColumn fx:id="colNom"      text="Nom"      prefWidth="200"/>
                        <TableColumn fx:id="colEmail"    text="Email"    prefWidth="245"/>
                        <TableColumn fx:id="colPassword" text="Password" prefWidth="120"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucun utilisateur." styleClass="admin-placeholder"/>
                    </placeholder>
                </TableView>
            </VBox>

            <VBox styleClass="admin-form-card" prefWidth="290" spacing="14">
                <Label fx:id="formTitleLabel" text="➕ Nouvel utilisateur"
                       styleClass="admin-form-title"/>
                <Separator/>
                <Label text="Nom complet *" styleClass="admin-field-label"/>
                <TextField fx:id="nomField" styleClass="admin-field"
                           promptText="Nom Prénom"/>
                <Label text="Email *" styleClass="admin-field-label"/>
                <TextField fx:id="emailField" styleClass="admin-field"
                           promptText="email@mail.com"/>
                <Label text="Mot de passe *" styleClass="admin-field-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="Laisser vide = inchangé"
                               styleClass="admin-field"/>
                <Label fx:id="errorLabel" styleClass="admin-error" wrapText="true"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Button text="💾 Sauvegarder" styleClass="admin-btn-primary"
                        maxWidth="Infinity" onAction="#sauvegarder"/>
                <Button fx:id="supprimerBtn" text="🗑 Supprimer"
                        styleClass="admin-btn-danger" maxWidth="Infinity"
                        onAction="#supprimer" disable="true"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
